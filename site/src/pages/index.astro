---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { getMeta, getEntity, groupedEntities, latestOf, prettyDate } from '../lib/data.mjs';
import { copyFor } from '../lib/content.mjs';

const meta = getMeta();
const groups = groupedEntities();
// Real dataset modification date = the newest effective date across all series (never the build date).
const dataModified = groups.flatMap((g) => g.entities.map((e) => latestOf(e)?.effective_date)).filter(Boolean).sort().at(-1);

// A featured strip of the most-searched current rates, one per jurisdiction where possible.
const FEATURED = ['irs-underpayment', 'us-federal-post-judgment', 'uk-late-payment-commercial', 'eu-late-payment-reference'];
const featured = FEATURED.map((slug) => {
  const e = getEntity(slug);
  return e ? { slug, name: e.name, latest: latestOf(e), jurisdiction: e.jurisdiction } : null;
}).filter(Boolean);
const JUR = { US: 'US', GB: 'UK', EU: 'EU' };
const title = `${meta.title} — Statutory, Judgment & Tax Interest Rates (current + historical)`;
const description = `Current and historical U.S. statutory interest rates: IRS §6621 quarterly rates, the federal post-judgment rate (28 U.S.C. §1961), and the 1-year Treasury yield. Each value with its effective date, official source, and a free JSON API.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${meta.title} — statutory, judgment & tax interest rates`,
  description: meta.description,
  url: new URL('/', Astro.site).href,
  isAccessibleForFree: true,
  creator: { '@type': 'Organization', name: meta.title },
  dateModified: dataModified,
  keywords: ['IRS interest rate', 'post-judgment interest rate', 'statutory interest', 'underpayment rate', 'Treasury 1-year CMT'],
  distribution: {
    '@type': 'DataDownload',
    encodingFormat: 'application/json',
    contentUrl: new URL('/api/v1/entities.json', Astro.site).href,
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <div class="eyebrow">Statutory interest rates · US · UK · EU</div>
  <h1>The interest rates the law actually charges — kept current</h1>
  <p class="lead">
    The interest rates the law and the IRS actually charge change every quarter or every week, so a
    figure you remember is usually already wrong. {meta.title} tracks each one with its effective date,
    a link to the official source, and a free JSON API for people and machines — across the US, UK, and EU.
  </p>

  <div class="featured">
    {featured.map((f) => (
      <a href={`/rates/${f.slug}/`}>
        <span class="chip">{JUR[f.jurisdiction] || f.jurisdiction}</span>
        <div class="fv">{f.latest?.value_text}</div>
        <div class="fn">{f.name}</div>
        <div class="fm">effective {prettyDate(f.latest?.effective_date)}</div>
      </a>
    ))}
  </div>

  <p class="browse"><a href="/states/">Rates by state →</a>
    &nbsp;·&nbsp; <a href="/prejudgment/">Prejudgment interest →</a>
    &nbsp;·&nbsp; <a href="/calculators/">Calculators →</a>
    &nbsp;·&nbsp; <a href="/guides/">Guides →</a>
    &nbsp;·&nbsp; <a href="/glossary/">Glossary →</a></p>

  <p class="trust">Every rate is <a href="/editorial-policy/">verified against the official statute</a> and
    stamped with its effective date — accuracy, not volume, is the point.</p>

  <AdSlot id="home-top" />

  {groups.map((g) => (
    <section>
      <h2>{g.title}</h2>
      {g.blurb && <p class="source-note" style="margin-top:-2px">{g.blurb}</p>}
      <div class="grid">
        {g.entities.map((e) => {
          const l = latestOf(e);
          return (
            <a class="card" href={`/rates/${e.slug}/`} style="display:block;color:inherit">
              <span class="chip">{JUR[e.jurisdiction] || e.jurisdiction}</span>
              <h3 style="margin-top:6px">{e.name}</h3>
              <div class="cval">{l?.value_text}</div>
              <div class="cmeta">
                effective {prettyDate(l?.effective_date)} ·
                {l?.confidence === 'high' ? ' published' : ' derived'}
              </div>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  <section class="pj-promo">
    <div>
      <div class="eyebrow" style="margin-bottom:6px">New · all 50 states + D.C.</div>
      <h2 style="margin-top:0">Prejudgment interest, state by state</h2>
      <p class="source-note" style="margin-top:-2px">Interest for the period <em>before</em> judgment — a
        different rate, and different rules. The hard part isn't the number; it's <em>whether it applies
        at all</em> (usually only on liquidated amounts). We track each state's rate, statute, and
        claim-type limits.</p>
    </div>
    <a class="pj-cta" href="/prejudgment/">Browse prejudgment rates →</a>
  </section>

  <AdSlot id="home-bottom" />

  <h2>Why this exists</h2>
  <p>
    These values are public and official, but scattered across quarterly IRS bulletins, a Federal
    Reserve data feed, and a statute that defines the post-judgment rate as a <em>formula</em> rather
    than a number. {meta.title} assembles them into one normalized, provenance-tracked, as-of-date
    dataset — the thing neither a single government page nor a language model gives you in one place.
    See <a href="/methodology/">methodology &amp; sources</a> and
    <a href="/about/">how this data is collected</a>.
  </p>

  <style>
    .browse { margin: 18px 0 0; font-family: var(--sans); font-size: 0.94rem; }
    .browse a { color: var(--green); text-decoration: none; font-weight: 600; border-bottom: 1px solid var(--line-strong); }
    .browse a:hover { border-bottom-color: var(--green); }
    .trust { margin: 14px 0 0; font-size: 0.9rem; color: var(--ink-soft); }
    .trust::before { content: '✓ '; color: var(--accent); font-weight: 700; }
    .trust a { color: var(--accent); font-weight: 600; }
    .pj-promo { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
      gap: 16px 28px; margin: 30px 0 8px; padding: 22px 24px; background: var(--green-wash);
      border: 1px solid var(--line-strong); border-left: 3px solid var(--green); border-radius: 2px; }
    .pj-promo > div { flex: 1 1 340px; }
    .pj-promo p { margin-bottom: 0; }
    .pj-cta { flex: 0 0 auto; align-self: center; font-family: var(--sans); font-weight: 700;
      font-size: 0.9rem; letter-spacing: 0.01em; color: var(--paper); background: var(--green);
      padding: 12px 20px; border-radius: 2px; text-decoration: none; white-space: nowrap; }
    .pj-cta:hover { background: var(--green-2); }
  </style>
</BaseLayout>
