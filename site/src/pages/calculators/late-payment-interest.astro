---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import InterestCalculator from '../../components/InterestCalculator.astro';
import { getMeta, getEntity, historyFor, latestOf, prettyDate } from '../../lib/data.mjs';

const meta = getMeta();
const uk = getEntity('uk-late-payment-commercial');
const ukLatest = latestOf(uk);
const euLatest = latestOf(getEntity('eu-late-payment-reference'));

const title = `Late Payment Interest Calculator — UK & EU Statutory Rates | ${meta.title}`;
const description = `Free late-payment interest calculators for overdue B2B invoices: UK statutory interest (currently ${ukLatest?.value_text} under the Late Payment Act 1998) and the EU Late Payment Directive (reference ${euLatest?.value_text} + 8pp floor). Updated ${prettyDate(meta.generated_at)}.`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Late Payment Interest Calculator (UK & EU)',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
    url: canonical,
    description: 'Computes statutory interest on overdue commercial invoices under the UK Late Payment Act 1998 and EU Directive 2011/7/EU.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How much interest can I charge on a late invoice in the UK?',
        acceptedAnswer: { '@type': 'Answer', text: `Statutory interest on late commercial (B2B) payments is the Bank of England base rate on the relevant reference date plus 8 percentage points — currently ${ukLatest?.value_text}. The rate is fixed when the debt becomes overdue and interest accrues daily as simple interest.` },
      },
      {
        '@type': 'Question',
        name: 'Is UK statutory late-payment interest simple or compound?',
        acceptedAnswer: { '@type': 'Answer', text: 'Simple — the Act implies a term of simple interest, computed daily (annual rate ÷ 365), fixed at the rate applicable when the debt became overdue. You may also claim fixed debt-recovery compensation (£40/£70/£100 by debt size).' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Calculators', item: new URL('/calculators/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Late payment interest (UK & EU)', item: canonical },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <nav aria-label="Breadcrumb" style="font-size:.9rem;color:var(--muted);margin-bottom:6px">
    <a href="/calculators/">Calculators</a> &rsaquo; <span>Late payment interest</span>
  </nav>
  <h1>Late payment interest calculator (UK &amp; EU)</h1>
  <p class="lead">What you can lawfully charge on an overdue B2B invoice — UK statutory interest under
    the Late Payment of Commercial Debts (Interest) Act 1998, and the EU Late Payment Directive rate.</p>

  <h2>United Kingdom</h2>
  <p>The statutory rate is the Bank of England base rate on the reference date (30 June / 31 December)
    <strong>before your invoice became overdue</strong>, plus 8 points — fixed for the whole late period,
    accruing daily as simple interest. Currently
    <a href="/rates/uk-late-payment-commercial/">{ukLatest?.value_text}</a>.</p>
  <InterestCalculator
    kind="fixed-simple"
    histories={{ uk: historyFor('uk-late-payment-commercial') }}
    defaultSeries="uk"
    currency="£"
    principalLabel="Invoice amount"
    startLabel="Date payment became overdue"
    endLabel="Calculated through (e.g. payment date)"
  />
  <p class="source-note">B2B (and business-to-public-authority) contracts only; consumer contracts are
    outside the Act. You can also claim fixed compensation per invoice: £40 (debt under £1,000), £70
    (£1,000–£9,999.99), or £100 (£10,000+).</p>

  <AdSlot id="calc-top" />

  <h2>European Union</h2>
  <p>Under Directive 2011/7/EU, the statutory rate is the ECB reference rate for the half-year
    (currently <a href="/rates/eu-late-payment-reference/">{euLatest?.value_text}</a>) plus your member
    state's margin — at least 8 points (the floor used below; France applies +10, Germany +9). Unlike
    the UK, the reference re-fixes each half-year, and this calculator accrues each period at its own rate.</p>
  <InterestCalculator
    kind="floating-simple"
    histories={{ eu: historyFor('eu-late-payment-reference') }}
    defaultSeries="eu"
    marginPercent={8}
    currency="€"
    principalLabel="Invoice amount"
    startLabel="Date payment became overdue"
    endLabel="Calculated through (e.g. payment date)"
  />
  <p class="source-note">Computed at the 8-point Directive floor; if your member state applies a higher
    margin, your entitlement is higher. Check the national implementing law for the exact margin.</p>

  <AdSlot id="calc-bottom" />
</BaseLayout>
