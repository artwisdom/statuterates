---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import InterestCalculator from '../../components/InterestCalculator.astro';
import { getMeta, getEntity, latestOf, prettyDate, PREJUDGMENT_CALC_SAFE, PREJUDGMENT_CALC_COMPOUND } from '../../lib/data.mjs';

const meta = getMeta();

// Safe set (a FIXED statutory rate with a deterministic method — simple, or annually compounded for
// Colorado) is defined once in data.mjs and reused by the cross-links; see it for what's excluded.
// Build rate histories + labels straight from the dataset so they never drift from the state pages.
// These are long-stable statutory rates, so the calculator extends the single current value back to
// 1990 to accept older accrual dates (the dataset itself keeps the strict effective date).
const COMPOUND = new Set(PREJUDGMENT_CALC_COMPOUND);
// Colorado is dual-rate (verified 2026-07-09): 8% general (C.R.S. §5-12-102) and 9% personal injury
// (C.R.S. §13-21-101), both compounded annually. Split into two clearly-labeled series rather than
// one ambiguous entry.
const CO_SERIES = [
  { key: 'colorado', name: 'Colorado (general/contract)', slug: 'colorado-prejudgment-rate', value: 8, value_text: '8%', cite: 'C.R.S. §5-12-102', compound: true },
  { key: 'colorado-pi', name: 'Colorado (personal injury)', slug: 'colorado-prejudgment-rate', value: 9, value_text: '9%', cite: 'C.R.S. §13-21-101', compound: true },
];
const entities = PREJUDGMENT_CALC_SAFE.flatMap((key) => {
  if (key === 'colorado') return CO_SERIES;
  const e = getEntity(`${key}-prejudgment-rate`);
  const l = latestOf(e);
  return [{
    key,
    name: e.name.replace(/ Prejudgment Interest Rate$/, ''),
    slug: `${key}-prejudgment-rate`,
    value: l?.value,
    value_text: l?.value_text,
    cite: e.metadata?.statute,
    compound: COMPOUND.has(key),
  }];
}).sort((a, b) => a.name.localeCompare(b.name));

const histories = Object.fromEntries(entities.map((e) => [e.key, [{ effective_date: '1990-01-01', value: e.value }]]));
const kinds = Object.fromEntries(entities.filter((e) => e.compound).map((e) => [e.key, 'fixed-compound']));
// Label with the COMPUTED rate (e.value = the fixed general/liquidated rate), not value_text, since a
// few states carry a separate variable tort rate the calculator does not compute (noted below).
const seriesOptions = entities.map((e) => ({ key: e.key, label: `${e.name} — ${e.value}%${e.compound ? ' · compounded annually' : ''}` }));
const defaultSeries = 'new-york';
const stateCount = PREJUDGMENT_CALC_SAFE.filter((k) => k !== 'dc').length; // distinct states; D.C. counted separately in copy

const title = `Prejudgment Interest Calculator by State | ${meta.title}`;
const description = `Free prejudgment interest calculator for the ${stateCount} states + D.C. with a fixed statutory rate (simple interest, plus Colorado's annual compounding). Enter the amount, the date interest began accruing, and the judgment date. Excludes formula-rate and discretionary states — see each state's page. Updated ${prettyDate(meta.generated_at)}.`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Prejudgment Interest Calculator (fixed-rate states)',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Web',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: canonical,
    description: `Computes prejudgment interest for the ${stateCount} U.S. states and D.C. that apply a fixed statutory rate (simple interest, or annual compounding in Colorado), from the accrual date to the date of judgment.`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How is prejudgment interest calculated?',
        acceptedAnswer: { '@type': 'Answer', text: 'In the states covered here it is simple interest on the principal from the date interest begins accruing (the date of loss, breach, or demand, depending on the claim) to the date judgment is entered: principal × annual rate × days ÷ 365. It applies only where the claim qualifies — generally a liquidated or readily ascertainable amount.' },
      },
      {
        '@type': 'Question',
        name: 'Why are only some states in this calculator?',
        acceptedAnswer: { '@type': 'Answer', text: 'A calculator is only honest where the rate is fixed by statute and the compounding rule is deterministic (simple interest, or fixed-rate annual compounding as in Colorado). States with a formula rate that changed over the accrual period, and states where prejudgment interest is discretionary, are excluded — computing a single number for those would mislead. Each has its own page explaining the method.' },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Calculators', item: new URL('/calculators/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Prejudgment interest', item: canonical },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <nav aria-label="Breadcrumb" style="font-size:.9rem;color:var(--ink-soft);margin-bottom:6px">
    <a href="/calculators/">Calculators</a> &rsaquo; <span>Prejudgment interest</span>
  </nav>
  <h1>Prejudgment interest calculator</h1>
  <p class="lead">Interest on a liquidated claim from the date it began accruing to the date of
    judgment, at each state's fixed statutory rate — verified against the statute and cited on its own
    page. Covers the <strong>{stateCount} states and D.C. where the rate is fixed</strong> (simple
    interest, plus Colorado's annual compounding), so the arithmetic is exact.</p>

  <div class="notice">
    <strong>Read this first.</strong> Prejudgment interest is not automatic. This calculator does the
    <em>arithmetic</em>; it does not decide the two things that actually govern an award:
    <ul>
      <li><strong>Whether it applies.</strong> Most of these states allow prejudgment interest only on
        <em>liquidated or readily ascertainable</em> amounts (a contract sum, an invoice) — and bar it
        on unliquidated damages (pain and suffering, most general tort damages). Confirm your claim
        qualifies on the <a href="/prejudgment/">state's page</a>.</li>
      <li><strong>When it starts.</strong> The accrual date is claim-dependent — date of loss, breach,
        demand, or filing. You set it below; each state's page states the rule.</li>
    </ul>
  </div>

  <InterestCalculator
    kind="fixed-simple"
    kinds={kinds}
    histories={histories}
    defaultSeries={defaultSeries}
    seriesOptions={seriesOptions}
    principalLabel="Claim amount (principal)"
    startLabel="Date interest begins accruing (claim-dependent)"
    endLabel="Date of judgment"
  />
  <p class="source-note">The rate for each state is pulled from the same dataset as its
    <a href="/prejudgment/">prejudgment rate page</a> and applied as simple interest, actual/365.
    Colorado compounds annually and has two rates: 8% general (C.R.S. §5-12-102) and 9% personal
    injury (C.R.S. §13-21-101, which runs from the date suit was filed — set that as the accrual date).
    This calculator uses each state's <strong>general / liquidated-claim</strong> rate; several states
    (Georgia, Idaho, Kansas, Montana, Nebraska, Utah) apply a <em>separate, usually variable</em> rate
    to tort or personal-injury claims — see the state's page for that figure. These statutory rates have been
    stable for years, so the calculator accepts accrual dates back to 1990 at the current rate.</p>

  <AdSlot id="calc-top" />

  <h2>States covered</h2>
  <p>Each of these applies a <strong>fixed statutory prejudgment rate</strong> — as simple interest,
    except Colorado, which compounds annually:</p>
  <div class="scroll-x">
    <table>
      <thead><tr><th scope="col">State</th><th scope="col">Rate</th><th scope="col">Method</th><th scope="col">Statute</th></tr></thead>
      <tbody>
        {entities.map((e) => (
          <tr>
            <td><a href={`/rates/${e.slug}/`}>{e.name}</a></td>
            <td class="num">{e.value}%</td>
            <td>{e.compound ? 'Compounded annually' : 'Simple'}</td>
            <td class="source-note">{e.cite}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Why other states aren't here</h2>
  <p>A prejudgment calculator is only honest when a single fixed rate applies and the compounding rule
    is deterministic. We leave out three groups on purpose, because one computed number would be
    misleading:</p>
  <ul class="clean">
    <li><strong>Formula / variable-rate states</strong> (e.g. Florida, Texas — and Michigan, whose rate
      resets twice a year and <em>also</em> compounds) — the rate <em>changed</em> over the years the
      interest accrued, so the correct figure stitches together each period's rate. See the state page
      for the current rate and formula.</li>
    <li><strong>Two-fixed-rate states</strong> (California, Illinois) — both rates are fixed, but which
      one applies turns on the claim (contract vs. tort/personal injury: California is 10% vs. 7%,
      Illinois 5% vs. 6%), so a single number would be ambiguous. Each state's page shows both.</li>
    <li><strong>Discretionary states</strong> (e.g. Virginia, Connecticut, Tennessee) — a court decides
      whether to award prejudgment interest and when it starts, so there is no automatic amount to compute.</li>
  </ul>
  <p class="source-note">Federal-court judgments use a different statute and compound annually — use the
    <a href="/calculators/post-judgment-interest/">federal post-judgment calculator</a>. Browse every
    state's rate and rules on the <a href="/prejudgment/">prejudgment interest index</a>.</p>

  <AdSlot id="calc-bottom" />

  <style>
    .notice { background: var(--paper-2); border: 1px solid var(--line); border-left: 3px solid var(--accent);
      border-radius: 10px; padding: 15px 18px; margin: 18px 0 6px; color: var(--ink-soft); font-size: 0.95rem; }
    .notice strong { color: var(--ink); }
    .notice ul { margin: 8px 0 0; padding-left: 20px; }
    .notice li { margin: 6px 0; }
    .notice a { color: var(--green); }
  </style>
</BaseLayout>
