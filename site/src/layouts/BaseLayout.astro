---
// Site-wide layout: SEO head, masthead, freshness stamp, and the design system.
// Aesthetic: "Modern Legal / Fintech" — crisp near-white, deep charcoal ink, a single confident indigo
// accent, Space Grotesk display + Inter body/tabular figures + Geist Mono data labels. Generous
// whitespace, hairline rules, soft card shadows. All fonts self-hosted -> no external requests.
import { getMeta, prettyDate } from '../lib/data.mjs';

const {
  title,
  description,
  jsonLd = null,
  noindex = false,
} = Astro.props;

const meta = getMeta();
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const origin = new URL('/', Astro.site).href;
const generatedDate = prettyDate(meta.generated_at);
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Site-wide entity schema on every page — establishes the publisher and site as a recognizable entity
// (durable SEO signal, enables richer knowledge-graph treatment). Per-page jsonLd is layered on top.
const siteJsonLd = [
  { '@context': 'https://schema.org', '@type': 'Organization', name: meta.title, url: origin, description: meta.description, logo: `${origin}logo-512.png` },
  { '@context': 'https://schema.org', '@type': 'WebSite', name: meta.title, url: origin, description: meta.description },
];

// ONE-SWITCH MONETIZATION: set the repo variable ADSENSE_CLIENT = ca-pub-XXXXXXXX (after AdSense
// approval) and redeploy — that turns on Google Auto Ads site-wide. Empty by default = no ad code ships.
const adsenseClient = process.env.ADSENSE_CLIENT || '';

// Privacy-respecting, cookieless traffic measurement: set the repo variable CF_ANALYTICS_TOKEN to the
// Cloudflare Web Analytics site token and redeploy. Empty by default = no beacon ships (no tracking).
const cfAnalyticsToken = process.env.CF_ANALYTICS_TOKEN || '';

const NAV = [
  { href: '/', label: 'Rates' },
  { href: '/states/', label: 'States' },
  { href: '/calculators/', label: 'Calculators' },
  { href: '/guides/', label: 'Guides' },
  { href: '/api/', label: 'Data & API' },
  { href: '/about/', label: 'About' },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <meta name="theme-color" content="#3a3fa6" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logo-512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />

    {adsenseClient && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous"></script>
    )}
    {cfAnalyticsToken && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}></script>
    )}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={meta.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${origin}og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${meta.title} — statutory, judgment & tax interest rates`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${origin}og-image.png`} />

    {[...siteJsonLd, ...jsonLdArray].map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <style is:global>
      @font-face { font-family: 'Inter'; src: url('/fonts/inter.woff2') format('woff2-variations'); font-weight: 100 900; font-style: normal; font-display: swap; }
      @font-face { font-family: 'Space Grotesk'; src: url('/fonts/space-grotesk.woff2') format('woff2-variations'); font-weight: 300 700; font-style: normal; font-display: swap; }
      @font-face { font-family: 'Geist Mono'; src: url('/fonts/geist-mono.woff2') format('woff2-variations'); font-weight: 100 900; font-style: normal; font-display: swap; }

      :root {
        /* Surfaces */
        --paper: #ffffff;
        --paper-2: #f7f8fb;     /* subtle panel / card wash */
        --paper-3: #eef1f7;     /* zebra / deeper wash */
        /* Ink */
        --ink: #14161d;         /* near-black, faintly cool */
        --ink-soft: #59616f;    /* slate muted */
        /* Hairlines */
        --line: #e9ebf1;
        --line-strong: #d7dbe4;
        /* Accent (indigo) — exposed via the legacy --green name so every page inherits it */
        --green: #3a3fa6;       /* primary accent */
        --green-2: #2c3086;     /* accent hover / deeper */
        --green-wash: #eef0fb;  /* accent tint background */
        --accent: #3a3fa6;
        --accent-bright: #5257d6;
        /* Legacy decorative tokens remapped so old page CSS stays coherent */
        --gold: #3a3fa6;
        --gold-2: #6c70de;
        --gold-ink: #3a3fa6;    /* numbered markers etc. */
        --amber-bg: #f7f8fb;    /* neutral notice/panel */
        --amber-ink: #59616f;
        /* Type */
        --sans: 'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        --serif: 'Space Grotesk', 'Inter', ui-sans-serif, sans-serif; /* repurposed: distinctive display */
        --display: 'Space Grotesk', 'Inter', ui-sans-serif, sans-serif;
        --nums: 'Inter', ui-sans-serif, sans-serif; /* tabular figures via font-variant-numeric */
        --mono: 'Geist Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
        --measure: 960px;
        --shadow-sm: 0 1px 2px rgba(20,22,29,0.05), 0 1px 3px rgba(20,22,29,0.04);
        --shadow-md: 0 6px 22px -6px rgba(20,22,29,0.14), 0 2px 6px rgba(20,22,29,0.06);
        --radius: 12px;
      }

      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--sans);
        color: var(--ink);
        background: var(--paper);
        line-height: 1.62;
        font-size: 17px;
        font-feature-settings: 'kern' 1, 'liga' 1, 'cv05' 1;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: rgba(58,63,166,0.16); }
      a { color: var(--accent); text-decoration: none; text-underline-offset: 2px; text-decoration-thickness: 1px; transition: color 120ms ease; }
      a:hover { color: var(--green-2); text-decoration: underline; }
      :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 3px; }
      .wrap { max-width: var(--measure); margin: 0 auto; padding: 0 24px; }

      /* ---- Masthead ---------------------------------------------------------- */
      header.site { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,0.82);
        backdrop-filter: saturate(180%) blur(14px); -webkit-backdrop-filter: saturate(180%) blur(14px);
        border-bottom: 1px solid var(--line); }
      header.site .wrap { display: flex; align-items: center; justify-content: space-between; gap: 20px; min-height: 66px; flex-wrap: wrap; }
      .brand { display: inline-flex; align-items: center; gap: 9px; color: var(--ink); }
      .brand:hover { text-decoration: none; }
      .brand .mark { display: inline-grid; place-items: center; width: 28px; height: 28px; border-radius: 8px;
        background: var(--accent); color: #fff; font-family: var(--display); font-weight: 600; font-size: 1.05rem; line-height: 1; box-shadow: var(--shadow-sm); }
      .brand .name { font-family: var(--display); font-weight: 600; font-size: 1.32rem; letter-spacing: -0.02em; color: var(--ink); }
      .brand .name b { font-weight: 600; }
      .brand .name i { font-style: normal; font-weight: 600; color: var(--accent); }
      header.site nav { display: flex; gap: 4px; flex-wrap: wrap; }
      header.site nav a { color: var(--ink-soft); font-size: 0.86rem; font-weight: 500; letter-spacing: -0.005em; padding: 7px 11px; border-radius: 8px; transition: color 120ms ease, background 120ms ease; }
      header.site nav a:hover { color: var(--ink); background: var(--paper-2); text-decoration: none; }
      header.site nav a[aria-current] { color: var(--accent); background: var(--green-wash); }

      main { padding: 46px 0 12px; }

      /* ---- Typography -------------------------------------------------------- */
      h1 { font-family: var(--sans); font-weight: 700; font-size: clamp(2.05rem, 4.6vw, 3.05rem); line-height: 1.05; letter-spacing: -0.033em; margin: 0 0 16px; }
      h2 { font-family: var(--sans); font-weight: 680; font-size: 1.5rem; line-height: 1.22; letter-spacing: -0.02em; margin: 44px 0 14px; }
      h3 { font-family: var(--sans); font-weight: 640; font-size: 1.1rem; letter-spacing: -0.01em; margin: 0 0 6px; }
      p { margin: 0 0 16px; }
      p.lead, .lead { font-size: 1.24rem; line-height: 1.5; color: #2b303b; max-width: 44rem; letter-spacing: -0.011em; font-weight: 420; }
      .eyebrow { font-family: var(--mono); font-size: 0.72rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-soft); margin-bottom: 12px; }
      strong, b { font-weight: 640; }
      .skip { position: absolute; left: -9999px; }
      .skip:focus { position: fixed; left: 10px; top: 10px; z-index: 100; background: var(--accent); color: #fff; padding: 9px 16px; border-radius: 8px; font-weight: 600; box-shadow: var(--shadow-md); }

      /* ---- Rate hero --------------------------------------------------------- */
      .rate-hero { margin: 26px 0 30px; padding: 26px 28px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 16px; }
      .rate-hero .eyebrow { margin-bottom: 6px; }
      .rate-hero .value { font-family: var(--nums); font-weight: 720; font-size: clamp(3rem, 8.5vw, 4.6rem); line-height: 0.98; color: var(--accent); letter-spacing: -0.04em; font-variant-numeric: tabular-nums lining-nums; display: block; }
      .rate-hero .asof { display: block; margin-top: 12px; color: var(--ink-soft); font-size: 0.96rem; }

      .badge { display: inline-block; font-family: var(--mono); font-size: 0.66rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 9px; border-radius: 999px; border: 1px solid transparent; }
      .badge.high { color: var(--accent); border-color: rgba(58,63,166,0.25); background: var(--green-wash); }
      .badge.medium { color: #7a5c17; border-color: #ecdcae; background: #fbf3df; }

      /* ---- Cards / grids ----------------------------------------------------- */
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; margin: 8px 0; }
      .card { position: relative; border: 1px solid var(--line); border-radius: var(--radius); padding: 18px 20px; background: var(--paper);
        box-shadow: var(--shadow-sm); transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease; }
      a.card:hover, .card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--line-strong); text-decoration: none; }
      .card h3 { margin: 8px 0 8px; }
      .card .cval { font-family: var(--nums); font-size: 1.9rem; font-weight: 700; color: var(--ink); line-height: 1; font-variant-numeric: tabular-nums lining-nums; letter-spacing: -0.03em; }
      .card .cmeta { color: var(--ink-soft); font-size: 0.82rem; margin-top: 8px; }

      /* ---- Featured stat strip ---------------------------------------------- */
      .featured { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 14px; margin: 28px 0 10px; }
      .featured a { display: block; color: inherit; padding: 18px 20px; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow-sm); transition: transform 140ms ease, box-shadow 140ms ease; }
      .featured a:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
      .featured .fv { font-family: var(--nums); font-size: 2.35rem; font-weight: 720; color: var(--accent); letter-spacing: -0.04em; line-height: 1; font-variant-numeric: tabular-nums lining-nums; margin-top: 10px; }
      .featured .fn { font-size: 0.9rem; color: var(--ink); margin-top: 9px; line-height: 1.35; font-weight: 500; }
      .featured .fm { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-soft); margin-top: 7px; }

      .chip { display: inline-block; font-family: var(--mono); font-size: 0.62rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 8px; border-radius: 999px; background: var(--green-wash); color: var(--accent); vertical-align: middle; }

      /* ---- Tables ------------------------------------------------------------ */
      table { border-collapse: collapse; width: 100%; font-size: 0.95rem; margin: 14px 0 6px; }
      caption { text-align: left; color: var(--ink-soft); font-size: 0.85rem; padding-bottom: 10px; font-family: var(--sans); }
      thead th { border-bottom: 1px solid var(--line-strong); }
      th, td { text-align: left; padding: 11px 14px; border-bottom: 1px solid var(--line); }
      th { font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-soft); font-weight: 500; }
      tbody tr { transition: background 100ms ease; }
      tbody tr:hover { background: var(--paper-2); }
      td.num { font-family: var(--nums); font-variant-numeric: tabular-nums lining-nums; font-weight: 640; font-size: 1rem; color: var(--ink); letter-spacing: -0.02em; }
      .scroll-x { overflow-x: auto; border-radius: var(--radius); }

      .source-note { font-size: 0.88rem; color: var(--ink-soft); }
      code { font-family: var(--mono); font-size: 0.84em; background: var(--paper-2); padding: 1px 6px; border-radius: 5px; border: 1px solid var(--line); }

      .disclaimer { background: var(--paper-2); border: 1px solid var(--line); border-left: 3px solid var(--accent); border-radius: 10px; padding: 15px 18px; font-size: 0.9rem; color: var(--ink-soft); margin: 22px 0; }
      .disclaimer strong { color: var(--ink); }
      ul.clean { padding-left: 20px; }
      ul.clean li { margin: 7px 0; }

      .sec-mark { text-align: center; color: var(--line-strong); font-family: var(--display); font-size: 1.2rem; margin: 36px 0; letter-spacing: 0.5em; }
      .sec-mark::before { content: '§ § §'; }

      /* ---- Footer ------------------------------------------------------------ */
      footer.site { margin-top: 64px; border-top: 1px solid var(--line); background: var(--paper-2); }
      footer.site .wrap { padding: 34px 24px 40px; color: var(--ink-soft); font-size: 0.9rem; }
      footer.site .fbrand { font-family: var(--display); font-size: 1.12rem; color: var(--ink); font-weight: 600; letter-spacing: -0.01em; }
      footer.site a { color: var(--ink-soft); }
      footer.site a:hover { color: var(--accent); }
      .freshness { color: var(--ink-soft); font-size: 0.85rem; font-family: var(--mono); }
      .ad-slot { margin: 26px 0; }

      @media (prefers-reduced-motion: reduce) { * { transition: none !important; scroll-behavior: auto; } }
      @media (max-width: 560px) {
        body { font-size: 16px; }
        header.site .wrap { min-height: 58px; gap: 12px; }
        header.site nav { gap: 2px; }
        header.site nav a { padding: 6px 8px; font-size: 0.82rem; }
        .grid { grid-template-columns: 1fr; }
        p.lead, .lead { font-size: 1.1rem; }
        .rate-hero { padding: 20px; }
      }
    </style>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="site">
      <div class="wrap">
        <a class="brand" href="/">
          <span class="mark">§</span>
          <span class="name"><b>Statute</b><i>Rates</i></span>
        </a>
        <nav aria-label="Primary">
          {NAV.map((n) => <a href={n.href} aria-current={(n.href === '/' ? path === '/' : path.startsWith(n.href)) ? 'page' : undefined}>{n.label}</a>)}
        </nav>
      </div>
    </header>
    <main id="main" tabindex="-1">
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site">
      <div class="wrap">
        <p><span class="fbrand">§ StatuteRates</span> — the statutory, judgment &amp; tax interest-rate reference.</p>
        <p class="freshness">Compiled {generatedDate}. Every value carries its effective date and official source.</p>
        <p>
          <a href="/guides/">Guides</a> ·
          <a href="/glossary/">Glossary</a> ·
          <a href="/methodology/">Methodology &amp; sources</a> ·
          <a href="/prejudgment/">Prejudgment interest by state</a> ·
          <a href="/states/highest-lowest/">Highest &amp; lowest rates</a> ·
          <a href="/calculators/">Calculators</a> ·
          <a href="/changes/">Rate changes (RSS)</a> ·
          <a href="/api/">JSON API</a> ·
          <a href="/about/">About</a> ·
          <a href="/llms.txt">llms.txt</a>
        </p>
        <p>
          <a href="/privacy/">Privacy</a> ·
          <a href="/terms/">Terms &amp; Disclaimer</a>
        </p>
        <p>Source values are US, UK &amp; EU government works. Reference data — not legal, tax, or financial advice.</p>
      </div>
    </footer>
  </body>
</html>
