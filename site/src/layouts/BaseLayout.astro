---
// Site-wide layout: SEO head, freshness stamp, header/footer, and a tiny inline stylesheet.
// No client-side framework, no web fonts, no external requests -> fast on emerging-market connections.
import { getMeta, prettyDate } from '../lib/data.mjs';

const {
  title,
  description,
  jsonLd = null, // object or array of schema.org JSON-LD objects
  noindex = false,
} = Astro.props;

const meta = getMeta();
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const generatedDate = prettyDate(meta.generated_at);
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <meta name="theme-color" content="#0b1f3a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph / Twitter (text-only; no external image dependency) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={meta.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    {jsonLdArray.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <style is:global>
      :root {
        --navy: #0b1f3a;
        --navy-2: #12294a;
        --accent: #1f6feb;
        --ink: #1a1f29;
        --muted: #5b6472;
        --line: #e4e8ee;
        --bg: #ffffff;
        --bg-soft: #f6f8fb;
        --good: #0f7b4f;
        --radius: 10px;
        --max: 940px;
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        color: var(--ink);
        background: var(--bg);
        line-height: 1.55;
        font-size: 17px;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap { max-width: var(--max); margin: 0 auto; padding: 0 20px; }
      header.site {
        background: var(--navy);
        color: #fff;
        border-bottom: 3px solid var(--accent);
      }
      header.site .wrap { display: flex; align-items: center; justify-content: space-between; gap: 16px; min-height: 60px; flex-wrap: wrap; }
      header.site a.brand { color: #fff; font-weight: 700; font-size: 1.15rem; letter-spacing: -0.01em; }
      header.site nav a { color: #cfe0f5; margin-left: 18px; font-size: 0.95rem; }
      header.site nav a:hover { color: #fff; }
      main { padding: 28px 0 8px; }
      h1 { font-size: 1.9rem; line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 10px; }
      h2 { font-size: 1.3rem; margin: 32px 0 10px; letter-spacing: -0.01em; }
      p.lead { font-size: 1.08rem; color: var(--muted); margin-top: 0; }
      .rate-hero {
        display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap;
        background: var(--bg-soft); border: 1px solid var(--line); border-radius: var(--radius);
        padding: 18px 20px; margin: 18px 0;
      }
      .rate-hero .value { font-size: 2.6rem; font-weight: 700; color: var(--navy); letter-spacing: -0.02em; }
      .rate-hero .asof { color: var(--muted); font-size: 0.95rem; }
      .badge { display: inline-block; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; padding: 2px 8px; border-radius: 999px; }
      .badge.high { background: #e4f5ec; color: var(--good); }
      .badge.medium { background: #fff3e0; color: #a15c00; }
      .card { border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 18px; margin: 10px 0; background: #fff; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
      .card h3 { margin: 0 0 4px; font-size: 1.05rem; }
      .card .cval { font-size: 1.5rem; font-weight: 700; color: var(--navy); }
      .card .cmeta { color: var(--muted); font-size: 0.85rem; }
      .chip { display: inline-block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; padding: 1px 7px; border-radius: 999px; background: #eef3fb; color: var(--accent); vertical-align: middle; }
      .featured { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; margin: 20px 0 8px; }
      .featured a { display: block; color: inherit; border: 1px solid var(--line); border-left: 4px solid var(--accent); border-radius: var(--radius); padding: 14px 16px; background: linear-gradient(180deg, #fbfcfe, #fff); }
      .featured a:hover { text-decoration: none; border-color: var(--accent); box-shadow: 0 2px 10px rgba(11,31,58,0.06); }
      .featured .fv { font-size: 1.9rem; font-weight: 700; color: var(--navy); letter-spacing: -0.02em; line-height: 1.1; }
      .featured .fn { font-size: 0.9rem; color: var(--ink); margin-top: 2px; }
      .featured .fm { font-size: 0.78rem; color: var(--muted); margin-top: 4px; }
      table { border-collapse: collapse; width: 100%; font-size: 0.95rem; margin: 10px 0 4px; }
      caption { text-align: left; color: var(--muted); font-size: 0.85rem; padding-bottom: 6px; }
      th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--line); }
      th { background: var(--bg-soft); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--muted); }
      td.num { font-variant-numeric: tabular-nums; font-weight: 600; }
      .scroll-x { overflow-x: auto; }
      .source-note { font-size: 0.88rem; color: var(--muted); }
      .disclaimer { background: #fffbef; border: 1px solid #f0e3b8; border-radius: var(--radius); padding: 12px 15px; font-size: 0.9rem; color: #5f5326; margin: 18px 0; }
      footer.site { margin-top: 40px; border-top: 1px solid var(--line); background: var(--bg-soft); }
      footer.site .wrap { padding: 22px 20px; color: var(--muted); font-size: 0.88rem; }
      footer.site a { color: var(--muted); text-decoration: underline; }
      .freshness { color: var(--muted); font-size: 0.85rem; }
      .ad-slot { margin: 20px 0; min-height: 0; }
      ul.clean { padding-left: 20px; }
      ul.clean li { margin: 4px 0; }
      @media (max-width: 520px) {
        body { font-size: 16px; }
        h1 { font-size: 1.55rem; }
        .rate-hero .value { font-size: 2.1rem; }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <a class="brand" href="/">{meta.title}</a>
        <nav>
          <a href="/">Rates</a>
          <a href="/calculators/">Calculators</a>
          <a href="/changes/">Changes</a>
          <a href="/api/">API</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site">
      <div class="wrap">
        <p class="freshness">Data last compiled {generatedDate}. Every value links to its official source and effective date.</p>
        <p>
          {meta.title} — reference data, not legal, tax, or financial advice.
          <a href="/about/">How this data is collected</a> ·
          <a href="/methodology/">Methodology &amp; sources</a> ·
          <a href="/calculators/">Calculators</a> ·
          <a href="/changes/">Rate changes (RSS)</a> ·
          <a href="/api/">JSON API</a> ·
          <a href="/llms.txt">llms.txt</a>
        </p>
        <p>Source values are U.S. federal government works (public domain). Compiled dataset © {meta.title}.</p>
      </div>
    </footer>
  </body>
</html>
