# Copy to `.env` (which is git-ignored) and fill in. NONE of these are secrets — there are no API
# keys or credentials anywhere in this project. These only tune the crawler's contact string and the
# site's production URL.

# Contact embedded in the crawler's User-Agent (an email or URL). Politeness best practice so the
# official sites you fetch can reach you. Optional but recommended before running the pipeline.
STATUTERATES_CONTACT=

# Production site URL used at build time for canonical links, sitemap, llms.txt, and API absolute
# URLs. Set to your real domain (or the *.pages.dev / *.github.io URL). Example:
# SITE_URL=https://statuterates.com
SITE_URL=
